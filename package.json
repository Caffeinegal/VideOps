{
  "scripts": {
    "start": "parcel ./src/index.html",
    "build:parcel": "rm -rf build && parcel build -d build --public-url ./ --no-source-maps ./src/index.html",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "npm run build:parcel && npm run zip",
    "test": "jest",
    "lint": "eslint src/**/*.ts tests/**/*.js --no-error-on-unmatched-pattern",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "bestzip": "^2.2.0",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "jest": "^30.3.0",
    "parcel-bundler": "^1.12.5",
    "sass": "^1.39.0",
    "ts-jest": "^29.2.5",
    "typescript": "^4.4.2"
  }
}
